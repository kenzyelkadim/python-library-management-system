print("Welcome to the library.")
library_books = ["the great gatsby", "harry potter", "kite runner", "the alchemist", "gone with the wind"]
book_prices = {"the great gatsby": 150, "harry potter": 200,"kite runner": 160,"the alchemist": 170, "gone with the wind": 190}
borrowed_books = []
def display_library_books():
    if not library_books:
        print("No books available.")
    else:
        print("Books in library:")
        for book in library_books:
            print("-", book)
def borrow_book():
    if not library_books:
        print("no books available to borrow.")
        return
    display_library_books()
    book_name = input("enter the name of the book you want to borrow: ").strip().lower()
    borrower_name = input("enter your name: ")
    try:
        borrower_id = int(input("enter your ID: "))
    except ValueError:
        print("invalid ID make sure you enter a number.")
        return
    for book in library_books:
        if book.lower() == book_name:
            library_books.remove(book)
            borrowed_books.append((book, borrower_name, borrower_id))
            print("you borrowed:", book)
            return
    print("book not found check the spelling.")
def return_book():
    book_name = input("enter the name of the book you want to return: ").strip().lower()

    for borrowed in borrowed_books:
        if borrowed[0].lower() == book_name:
            borrowed_books.remove(borrowed)
            library_books.append(borrowed[0])
            print("thank you for returning:", borrowed[0])
            return

    print("this book was not borrowed from here!")

def donate_book():
    book_name = input("enter the name of the book you want to donate: ").strip()
    if book_name in library_books:
        print("book already exists in the library.")
        return
    library_books.append(book_name)
    pages = int(input("enter the number of pages of the book: ").strip())

    if pages <= 0:
        print("please enter a valid number of pages greater than 0.")
        return
    if pages > 800:
        book_prices[book_name] = 190
    elif pages > 400:
        book_prices[book_name] = 145
    else:
        book_prices[book_name] = 110

    print("thank you for donating:", book_name)

def buy_book():
    if not library_books:
        print("no books available to buy.")
        return

    display_library_books()

    book_name = input("enter the name of the book you want to buy: ").strip().lower()

    for book in library_books:
        if book.lower() == book_name:
            print("the price is", book_prices[book], "egp")

            decision = input("to confirm, enter X: ").strip().lower()
            if decision == "x":
                library_books.remove(book)
                print("you bought:", book)
            else:
                print("purchase cancelled.")

            return

    print("book not found")

def count_books():
    print("the total number of books is:", len(library_books))


def view_borrowed_books():
    if not borrowed_books:
        print("no books are currently borrowed.")
    else:
        print("borrowed books:")
        for book, name, id_num in borrowed_books:
            print("-", book, "borrowed by", name, "(ID:", id_num, ")")


def library_menu():
    while True:
        print("LIBRARY MANAGEMENT SYSTEM")
        print("1. View All Books")
        print("2. Borrow a Book")
        print("3. Return a Book")
        print("4. Buy a Book")
        print("5. Donate a Book")
        print("6. Count Books")
        print("7. View Borrowed Books")
        print("8. Exit")

        choice = input("Enter your choice (1–8): ").strip()

        if choice == "1":
            display_library_books()
            input("press to continue...")
        elif choice == "2":
            borrow_book()
            input("press to continue...")
        elif choice == "3":
            return_book()
            input("press to continue...")
        elif choice == "4":
            buy_book()
            input("press to continue...")
        elif choice == "5":
            donate_book()
            input("press to continue...")
        elif choice == "6":
            count_books()
            input("press to continue...")
        elif choice == "7":
            view_borrowed_books()
            input("press to continue...")
        elif choice == "8":
            print("goodbye!")
            input("press to continue...")
            break
        else:
            print("invalid choice! Please enter 1–8.")
            input("press to continue...")
library_menu()
